# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # Never expose this client-side

# ─── Clerk ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_
CLERK_SECRET_KEY=sk_test_
CLERK_WEBHOOK_SECRET=whsec_           # From Clerk Dashboard > Webhooks

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379      # Use Upstash or Redis Cloud for prod

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-
OPENAI_API_KEY=sk-                    # Used only for embeddings

# ─── Pinecone ─────────────────────────────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX=docs-index             # Create this index with 1536 dimensions

# ─── Stripe ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_          # From Stripe Dashboard > Webhooks

# ─── SendGrid ─────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.
EMAIL_FROM=noreply@yourdomain.com     # Must be a verified sender in SendGrid
